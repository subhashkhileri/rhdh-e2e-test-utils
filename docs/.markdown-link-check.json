{
  "ignorePatterns": [
    { "pattern": "^<!--@include:" },
    { "pattern": "^/" },
    { "pattern": "^\\.{1,2}/" },
    { "pattern": "^#" }
  ],
  "httpHeaders": [
    {
      "urls": ["https://github.com"],
      "headers": { "Accept": "text/html" }
    }
  ],
  "timeout": "10s",
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "5s",
  "aliveStatusCodes": [200, 206, 301, 302]
}
